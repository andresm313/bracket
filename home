</head>
<body class="bg-gray-100 min-h-screen">
<div id="root"></div>
<script type="text/babel">
const { useState, useEffect } = React;

function combinations(arr, k) {
  if (k > arr.length || k <= 0) return [];
  if (k === arr.length) return [[...arr]];
  if (k === 1) return arr.map(el => [el]);
  const result = [];
  for (let i = 0; i <= arr.length - k; i++) {
    const rest = combinations(arr.slice(i + 1), k - 1);
    rest.forEach(c => result.push([arr[i], ...c]));
  }
  return result;
}

function uid() {
  return Math.random().toString(36).slice(2, 10);
}

function validateGroup(wrestlers) {
  const errors = [];
  if (wrestlers.length < 2) return errors;
  const weights = wrestlers.map(w => w.weight);
  const ages    = wrestlers.map(w => w.age);
  const maxW = Math.max(...weights), minW = Math.min(...weights);
  const maxA = Math.max(...ages),    minA = Math.min(...ages);
  if (maxW - minW > 10)
    errors.push(`Weight spread ${minW}–${maxW} lbs exceeds 10 lb limit`);
  if (maxA - minA > 1)
    errors.push(`Age gap ${minA}–${maxA} years exceeds 1-year limit`);
  const hasB = wrestlers.some(w => w.experience === 'Beginner');
  const hasA = wrestlers.some(w => w.experience === 'Advanced');
  const hasI = wrestlers.some(w => w.experience === 'Intermediate');
  if (hasB && hasA)
    errors.push('Beginners cannot wrestle Advanced wrestlers');
  if (hasI && hasA) {
    const youngI = wrestlers.find(w => w.experience === 'Intermediate' && w.age < 14);
    if (youngI)
      errors.push(`${youngI.name} (Intermediate, age ${youngI.age}) must be 14+ to wrestle Advanced`);
  }
  if (wrestlers.length > 4)
    errors.push('Groups cannot have more than 4 wrestlers');
  return errors;
}

function isValidGroup(w) { return validateGroup(w).length === 0; }

function generateGroups(wrestlers) {
  const sorted = [...wrestlers].sort((a, b) => a.weight - b.weight);
  const remaining = [...sorted];
  const groups = [];
  const unassigned = [];
  while (remaining.length > 0) {
    const anchor = remaining[0];
    const candidates = remaining.filter(w => w.weight - anchor.weight <= 10);
    let group = null;
    if (candidates.length >= 4) {
      for (const combo of combinations(candidates, 4)) {
        if (isValidGroup(combo)) { group = combo; break; }
      }
    }
    if (!group && candidates.length >= 3) {
      for (const combo of combinations(candidates, 3)) {
        if (isValidGroup(combo)) { group = combo; break; }
      }
    }
    if (group) {
      groups.push({ id: uid(), label: '', wrestlers: group });
      group.forEach(w => remaining.splice(remaining.findIndex(r => r.id === w.id), 1));
    } else {
      unassigned.push(anchor);
      remaining.shift();
    }
  }
  groups.forEach((g, i) => { g.label = String.fromCharCode(65 + i); });
  return { groups, unassigned };
}

function buildMatches(group) {
  const w = group.wrestlers;
  const n = w.length;
  const rawMatches = [];
  if (n === 3) {
    rawMatches.push({ round: 1, w1: w[0], w2: w[1] });
    rawMatches.push({ round: 2, w1: w[0], w2: w[2] });
    rawMatches.push({ round: 3, w1: w[1], w2: w[2] });
  } else if (n === 4) {
    rawMatches.push({ round: 1, w1: w[0], w2: w[3] });
    rawMatches.push({ round: 1, w1: w[1], w2: w[2] });
    rawMatches.push({ round: 2, w1: w[0], w2: w[1] });
    rawMatches.push({ round: 2, w1: w[2], w2: w[3] });
    rawMatches.push({ round: 3, w1: w[0], w2: w[2] });
    rawMatches.push({ round: 3, w1: w[1], w2: w[3] });
  }
  return rawMatches.map(m => ({
    ...m, id: uid(), groupId: group.id, groupLabel: group.label, winner: null, mat: 1,
  }));
}

function generateSchedule(groups, numMats) {
  const matAssign = {};
  groups.forEach((g, i) => { matAssign[g.id] = (i % numMats) + 1; });
  const matches = [];
  groups.forEach(g => {
    const gMatches = buildMatches(g).map(m => ({ ...m, mat: matAssign[g.id] }));
    matches.push(...gMatches);
  });
  return matches;
}

function computeStandings(group, matches) {
  const rows = group.wrestlers.map(w => ({ wrestler: w, wins: 0, losses: 0, points: 0 }));
  matches
    .filter(m => m.groupId === group.id && m.winner)
    .forEach(m => {
      const loserId = m.winner === m.w1.id ? m.w2.id : m.w1.id;
      const win = rows.find(r => r.wrestler.id === m.winner);
      const los = rows.find(r => r.wrestler.id === loserId);
      if (win) { win.wins++; win.points += 6; }
      if (los) { los.losses++; }
    });
  rows.sort((a, b) => b.points - a.points || b.wins - a.wins);
  return rows;
}

function parseCSV(text) {
  const lines = text.trim().split(/\r?\n/);
  if (lines.length < 2) return [];
  const headers = lines[0].split(',').map(h => h.trim().toLowerCase().replace(/\s+/g,''));
  return lines.slice(1).map((line, i) => {
    const vals = line.split(',').map(v => v.trim());
    const obj = {};
    headers.forEach((h, j) => { obj[h] = vals[j] || ''; });
    return {
      id: uid(),
      name:       obj.name || `Wrestler ${i + 1}`,
      age:        parseFloat(obj.age) || 14,
      grade:      obj.grade || '',
      experience: ['Beginner','Intermediate','Advanced'].includes(obj.experience) ? obj.experience : 'Beginner',
      weight:     parseFloat(obj.weight) || 130,
    };
  }).filter(w => w.name && w.weight > 0);
}

const save = (k, v) => { try { localStorage.setItem('wt_' + k, JSON.stringify(v)); } catch (_) {} };
const load = (k, fb) => { try { const s = localStorage.getItem('wt_' + k); return s ? JSON.parse(s) : fb; } catch (_) { return fb; } };

const SAMPLE_CSV = `Name,Age,Grade,Experience,Weight
Alex Johnson,14,9th,Beginner,125
Maria Santos,15,10th,Intermediate,132
Chris Lee,14,9th,Intermediate,128
Jordan Kim,16,11th,Advanced,155
Sam Rivera,15,10th,Beginner,120
Taylor Brown,16,11th,Advanced,160
Casey Wilson,14,9th,Beginner,115
