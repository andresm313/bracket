Riley Chen,14,9th,Beginner,122
Jamie Garcia,15,10th,Intermediate,150
Drew Martinez,16,11th,Advanced,158
Skyler Patel,14,9th,Beginner,118
Blake Thompson,15,10th,Intermediate,140
Avery Robinson,16,11th,Advanced,165`;

const EXP_BADGE = {
  Beginner:     'bg-emerald-100 text-emerald-800',
  Intermediate: 'bg-amber-100 text-amber-800',
  Advanced:     'bg-rose-100 text-rose-800',
};

function Badge({ text }) {
  return (
    <span className={`text-xs font-semibold px-2 py-0.5 rounded-full ${EXP_BADGE[text] || 'bg-gray-100 text-gray-600'}`}>
      {text ? text[0] : '?'}
    </span>
  );
}

function Nav({ page, setPage, wrestlers, groups }) {
  const tabs = [
    { id: 'upload',    icon: '①', label: 'Upload',    badge: wrestlers.length || null },
    { id: 'groups',    icon: '②', label: 'Groups',    badge: groups.length || null },
    { id: 'schedule',  icon: '③', label: 'Schedule',  badge: null },
    { id: 'results',   icon: '④', label: 'Results',   badge: null },
    { id: 'standings', icon: '⑤', label: 'Standings', badge: null },
  ];
  return (
    <nav className="bg-blue-950 text-white shadow-xl sticky top-0 z-50">
      <div className="max-w-7xl mx-auto px-4 py-3 flex items-center gap-1 flex-wrap">
        <div className="font-bold text-yellow-400 text-lg mr-4 whitespace-nowrap">🤼 Tournament Manager</div>
        {tabs.map(t => (
          <button key={t.id} onClick={() => setPage(t.id)}
            className={`relative px-3 py-1.5 rounded-lg text-sm font-medium transition-all ${
              page === t.id ? 'bg-yellow-400 text-blue-950 shadow' : 'text-blue-200 hover:bg-blue-800'
            }`}>
            {t.icon} {t.label}
            {t.badge ? (
              <span className="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] rounded-full w-4 h-4 flex items-center justify-center">
                {t.badge > 99 ? '99+' : t.badge}
              </span>
            ) : null}
          </button>
        ))}
      </div>
    </nav>
  );
}

function UploadPage({ wrestlers, setWrestlers }) {
  const [paste, setPaste] = useState('');
  const [err, setErr]     = useState('');
  const [editId, setEditId] = useState(null);

  function importCSV(text) {
    try {
      const parsed = parseCSV(text);
      if (!parsed.length) throw new Error('No valid rows found');
      setWrestlers(parsed);
      setErr('');
    } catch (e) { setErr(e.message || 'Could not parse. Check format.'); }
  }

  function handleFile(e) {
    const file = e.target.files[0];
    if (!file) return;
    const r = new FileReader();
    r.onload = ev => importCSV(ev.target.result);
    r.readAsText(file);
    e.target.value = '';
  }

  function update(id, field, val) {
    setWrestlers(wrestlers.map(w =>
      w.id !== id ? w : { ...w, [field]: (field === 'age' || field === 'weight') ? (parseFloat(val) || 0) : val }
    ));
  }

  function addRow() {
    const nw = { id: uid(), name: 'New Wrestler', age: 14, grade: '9th', experience: 'Beginner', weight: 130 };
    setWrestlers([...wrestlers, nw]);
    setEditId(nw.id);
  }

  function downloadSample() {
    const blob = new Blob([SAMPLE_CSV], { type: 'text/csv' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'sample_wrestlers.csv';
    a.click();
  }

  return (
    <div className="p-6 max-w-6xl mx-auto">
      <h1 className="text-2xl font-bold text-blue-950 mb-6">① Upload Wrestlers</h1>
      <div className="grid md:grid-cols-2 gap-5 mb-8">
        <div className="bg-white rounded-2xl shadow p-5 border-2 border-dashed border-blue-200">
          <h2 className="font-bold text-blue-800 mb-3">📁 Upload CSV File</h2>
          <input type="file" accept=".csv,.txt" onChange={handleFile}
            className="block w-full text-sm file:mr-3 file:py-2 file:px-4 file:rounded-lg file:bg-blue-700 file:text-white file:border-0 file:font-medium cursor-pointer" />
          <p className="text-xs text-gray-400 mt-2">Required columns: Name, Age, Grade, Experience, Weight</p>
          <button onClick={downloadSample} className="mt-2 text-xs text-blue-600 underline">↓ Download sample CSV</button>
        </div>
        <div className="bg-white rounded-2xl shadow p-5">
          <h2 className="font-bold text-blue-800 mb-3">📋 Paste CSV Data</h2>
          <textarea className="w-full h-28 border rounded-lg p-2 text-xs font-mono resize-none focus:outline-none focus:ring-2 focus:ring-blue-400"
            placeholder={"Name,Age,Grade,Experience,Weight\nAlex,14,9th,Beginner,125\n..."}
            value={paste} onChange={e => setPaste(e.target.value)} />
          <button onClick={() => importCSV(paste)}
            className="mt-2 bg-blue-700 text-white px-4 py-2 rounded-lg hover:bg-blue-800 text-sm font-medium">Import</button>
          <button onClick={() => importCSV(SAMPLE_CSV)}
            className="mt-2 ml-2 text-blue-600 border border-blue-300 px-4 py-2 rounded-lg hover:bg-blue-50 text-sm">Load Sample</button>
        </div>
      </div>
      {err && <div className="bg-red-50 border border-red-300 text-red-700 rounded-xl p-3 mb-4 text-sm">⚠️ {err}</div>}
      <div className="bg-white rounded-2xl shadow overflow-hidden">
        <div className="flex items-center justify-between px-5 py-4 border-b bg-gray-50">
          <h2 className="font-bold text-blue-900">Wrestler Roster <span className="text-gray-400 font-normal text-sm">({wrestlers.length})</span></h2>
          <button onClick={addRow} className="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 text-sm font-medium">+ Add Row</button>
        </div>
        {wrestlers.length === 0 ? (
          <div className="p-12 text-center text-gray-400">
            <div className="text-4xl mb-3">🤼</div>
            Upload a CSV, paste data, or load sample data to get started.
          </div>
        ) : (
          <div className="overflow-x-auto">
            <table className="w-full text-sm">
              <thead>
                <tr className="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
                  {['Name','Age','Grade','Experience','Weight (lbs)',''].map(h => (
                    <th key={h} className="text-left px-4 py-2 font-semibold">{h}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {wrestlers.map(w => (
                  <tr key={w.id} className="border-t hover:bg-gray-50 transition-colors">
                    {editId === w.id ? (
                      <>
                        <td className="px-2 py-1"><input className="border rounded px-2 py-1 w-40 text-sm" value={w.name} onChange={e => update(w.id,'name',e.target.value)} /></td>
                        <td className="px-2 py-1"><input type="number" className="border rounded px-2 py-1 w-16 text-sm" value={w.age} onChange={e => update(w.id,'age',e.target.value)} /></td>
                        <td className="px-2 py-1"><input className="border rounded px-2 py-1 w-16 text-sm" value={w.grade} onChange={e => update(w.id,'grade',e.target.value)} /></td>
                        <td className="px-2 py-1">
                          <select className="border rounded px-2 py-1 text-sm" value={w.experience} onChange={e => update(w.id,'experience',e.target.value)}>
                            <option>Beginner</option><option>Intermediate</option><option>Advanced</option>
                          </select>
                        </td>
                        <td className="px-2 py-1"><input type="number" step="0.5" className="border rounded px-2 py-1 w-20 text-sm" value={w.weight} onChange={e => update(w.id,'weight',e.target.value)} /></td>
                        <td className="px-2 py-1"><button onClick={() => setEditId(null)} className="text-green-600 font-semibold text-xs hover:underline">✓ Done</button></td>
                      </>
                    ) : (
                      <>
                        <td className="px-4 py-2.5 font-medium text-gray-900">{w.name}</td>
                        <td className="px-4 py-2.5 text-gray-600">{w.age}</td>
                        <td className="px-4 py-2.5 text-gray-600">{w.grade}</td>
                        <td className="px-4 py-2.5"><Badge text={w.experience} /></td>
                        <td className="px-4 py-2.5 font-mono text-gray-700">{w.weight}</td>
                        <td className="px-4 py-2.5 flex gap-3">
                          <button onClick={() => setEditId(w.id)} className="text-blue-600 text-xs hover:underline">Edit</button>
                          <button onClick={() => setWrestlers(wrestlers.filter(x => x.id !== w.id))} className="text-red-400 text-xs hover:underline">Remove</button>
                        </td>
                      </>
                    )}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  );
}

function GroupsPage({ wrestlers, groups, setGroups, unassigned, setUnassigned, setMatches }) {
  const [moving, setMoving] = useState(null);
  const [warnings, setWarnings] = useState({});

  function handleGenerate() {
    const { groups: g, unassigned: u } = generateGroups(wrestlers);
    setGroups(g); setUnassigned(u); setMatches([]); setWarnings({}); setMoving(null);
  }

  function recheckWarnings(grps) {
    const w = {};
    grps.forEach(g => { const errs = validateGroup(g.wrestlers); if (errs.length) w[g.id] = errs; });
    setWarnings(w);
  }

  function finishMove(toGroupId) {
    if (!moving) return;
    const { fromGroupId, wrestlerId } = moving;
    let wrestler = null;
    let newGroups = groups.map(g => {
      if (g.id === fromGroupId) {
        wrestler = g.wrestlers.find(w => w.id === wrestlerId);
        return { ...g, wrestlers: g.wrestlers.filter(w => w.id !== wrestlerId) };
      }
      return g;
    });
    let newUnassigned = unassigned;
    if (!wrestler) {
      wrestler = unassigned.find(w => w.id === wrestlerId);
      newUnassigned = unassigned.filter(w => w.id !== wrestlerId);
    }
    if (!wrestler) { setMoving(null); return; }
    if (toGroupId === '__new__') {
      const newG = { id: uid(), label: '', wrestlers: [wrestler] };
      newGroups = [...newGroups, newG];
    } else {
      newGroups = newGroups.map(g => g.id === toGroupId ? { ...g, wrestlers: [...g.wrestlers, wrestler] } : g);
    }
    const cleaned = newGroups.filter(g => g.wrestlers.length > 0);
    cleaned.forEach((g, i) => { g.label = String.fromCharCode(65 + i); });
    setGroups(cleaned); setUnassigned(newUnassigned); setMatches([]);
    recheckWarnings(cleaned); setMoving(null);
  }

  function sendToUnassigned(groupId, wrestlerId) {
    let wrestler = null;
    const newGroups = groups.map(g => {
      if (g.id === groupId) { wrestler = g.wrestlers.find(w => w.id === wrestlerId); return { ...g, wrestlers: g.wrestlers.filter(w => w.id !== wrestlerId) }; }
      return g;
    });
    if (!wrestler) return;
    const cleaned = newGroups.filter(g => g.wrestlers.length > 0);
    cleaned.forEach((g, i) => { g.label = String.fromCharCode(65 + i); });
    setGroups(cleaned); setUnassigned([...unassigned, wrestler]); setMatches([]);
    recheckWarnings(cleaned);
  }

  return (
    <div className="p-6 max-w-6xl mx-auto">
      <div className="flex items-center justify-between mb-6 flex-wrap gap-3">
        <div>
          <h1 className="text-2xl font-bold text-blue-950">② Bracket Groups</h1>
          {Object.keys(warnings).length > 0 && <p className="text-sm text-red-600 mt-1">⚠️ {Object.keys(warnings).length} group(s) have rule violations</p>}
        </div>
        <button onClick={handleGenerate} disabled={wrestlers.length < 3}
          className="bg-blue-800 text-white px-5 py-2.5 rounded-xl hover:bg-blue-900 disabled:opacity-40 font-semibold shadow">
          ⚙️ Auto-Generate Groups ({wrestlers.length} wrestlers)
        </button>
      </div>
      {groups.length === 0 && unassigned.length === 0 && (
        <div className="bg-blue-50 border border-blue-200 rounded-2xl p-10 text-center text-blue-700">
          <div className="text-4xl mb-3">⚙️</div>
          Click <strong>Auto-Generate Groups</strong> to create brackets automatically.
        </div>
      )}
      {moving && (
        <div className="bg-yellow-50 border-2 border-yellow-400 rounded-xl p-3 mb-4 text-sm text-yellow-800 flex items-center justify-between">
          <span>📌 Click a group to move this wrestler into it</span>
          <button onClick={() => setMoving(null)} className="font-semibold underline ml-4">✕ Cancel</button>
        </div>
      )}
      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {groups.map(group => {
          const errs = warnings[group.id] || [];
          const isTarget = moving && moving.fromGroupId !== group.id;
          return (
            <div key={group.id} onClick={() => isTarget && finishMove(group.id)}
              className={`bg-white rounded-2xl shadow p-4 border-2 transition-all ${
                errs.length ? 'border-red-400' : isTarget ? 'border-blue-400 ring-2 ring-blue-200 cursor-pointer hover:border-blue-600' : 'border-transparent'
              }`}>
              <div className="flex items-center justify-between mb-3">
                <div className="flex items-center gap-2">
                  <span className="bg-blue-900 text-white font-bold text-lg w-9 h-9 rounded-full flex items-center justify-center">{group.label}</span>
                  <span className="text-gray-500 text-sm">{group.wrestlers.length} wrestlers</span>
                </div>
                {group.wrestlers.length > 0 && (
                  <span className="text-xs text-gray-400 font-mono">
                    {Math.min(...group.wrestlers.map(w=>w.weight))}–{Math.max(...group.wrestlers.map(w=>w.weight))} lbs
                  </span>
                )}
              </div>
              {errs.length > 0 && (
                <div className="bg-red-50 rounded-lg p-2 mb-3 text-xs text-red-700 space-y-0.5">
                  {errs.map((e, i) => <div key={i}>⚠️ {e}</div>)}
                </div>
              )}
              <div className="space-y-1">
                {group.wrestlers.map(w => (
                  <div key={w.id} className={`flex items-center justify-between py-1.5 px-2 rounded-lg text-sm ${moving?.wrestlerId === w.id ? 'bg-blue-100 ring-1 ring-blue-400' : 'hover:bg-gray-50'}`}>
                    <div className="flex items-center gap-2 overflow-hidden">
                      <Badge text={w.experience} />
                      <span className="font-medium truncate">{w.name}</span>
                    </div>
                    <div className="flex items-center gap-1 shrink-0 ml-2">
                      <span className="text-gray-400 text-xs font-mono">{w.weight}</span>
                      <span className="text-gray-300 text-xs">· {w.age}y</span>
                      <button onClick={e => { e.stopPropagation(); setMoving({ fromGroupId: group.id, wrestlerId: w.id }); }} className="ml-1 text-blue-500 text-xs hover:underline">↕</button>
                      <button onClick={e => { e.stopPropagation(); sendToUnassigned(group.id, w.id); }} className="text-gray-300 text-xs hover:text-red-400">✕</button>
                    </div>
                  </div>
                ))}
              </div>
              {group.wrestlers.length > 0 && (
                <div className="mt-3 pt-2 border-t flex gap-2 text-xs text-gray-400">
                  <span>🎂 Age {Math.min(...group.wrestlers.map(w=>w.age))}–{Math.max(...group.wrestlers.map(w=>w.age))}</span>
                  <span>·</span>
                  <span className={errs.length ? 'text-red-400' : 'text-green-600'}>{errs.length ? '✗ Invalid' : '✓ Valid'}</span>
                </div>
              )}
            </div>
          );
        })}
        {moving && (
          <div onClick={() => finishMove('__new__')}
            className="bg-gray-50 rounded-2xl border-2 border-dashed border-gray-300 flex items-center justify-center cursor-pointer hover:border-blue-400 hover:bg-blue-50 transition-all min-h-36">
            <span className="text-gray-400 text-sm font-medium">+ New Group</span>
          </div>
        )}
      </div>
      {unassigned.length > 0 && (
        <div className="mt-6 bg-orange-50 rounded-2xl border border-orange-200 p-5">
          <h2 className="font-bold text-orange-800 mb-1">⚠️ Unassigned Wrestlers ({unassigned.length})</h2>
          <p className="text-xs text-orange-600 mb-3">Couldn't be auto-placed in a valid group. Use ↕ to move them manually.</p>
          <div className="flex flex-wrap gap-2">
            {unassigned.map(w => (
              <div key={w.id} className={`bg-white border rounded-xl px-3 py-2 text-sm flex items-center gap-2 shadow-sm ${moving?.wrestlerId === w.id ? 'border-blue-400 bg-blue-50' : 'border-orange-200'}`}>
                <Badge text={w.experience} />
                <span className="font-medium">{w.name}</span>
                <span className="text-gray-400 text-xs font-mono">{w.weight}lbs · {w.age}y</span>
                <button onClick={() => setMoving({ fromGroupId: '__unassigned__', wrestlerId: w.id })} className="text-blue-500 text-xs hover:underline">↕ Move</button>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}

function SchedulePage({ groups, numMats, setNumMats, matches, setMatches }) {
  const rounds = [...new Set(matches.map(m => m.round))].sort((a,b)=>a-b);
  const mats   = [...new Set(matches.map(m => m.mat))].sort((a,b)=>a-b);
  const done   = matches.filter(m => m.winner).length;

  return (
    <div className="p-6 max-w-6xl mx-auto">
      <div className="flex items-center gap-4 mb-6 flex-wrap">
        <h1 className="text-2xl font-bold text-blue-950">③ Match Schedule</h1>
        <div className="flex items-center gap-2 bg-white rounded-xl shadow px-3 py-2">
          <label className="text-sm font-medium text-gray-600">Mats:</label>
          <select value={numMats} onChange={e => setNumMats(parseInt(e.target.value))} className="border-0 text-sm font-bold focus:outline-none bg-transparent">
            {[1,2,3,4,5,6].map(n => <option key={n} value={n}>{n}</option>)}
          </select>
        </div>
        <button onClick={() => setMatches(generateSchedule(groups, numMats))} disabled={groups.length === 0}
          className="bg-blue-800 text-white px-5 py-2.5 rounded-xl hover:bg-blue-900 disabled:opacity-40 font-semibold shadow">
          📋 Generate Schedule
        </button>
        {matches.length > 0 && <span className="text-sm text-gray-500 ml-auto">{done}/{matches.length} matches completed</span>}
      </div>
      {matches.length === 0 ? (
        <div className="bg-blue-50 border border-blue-200 rounded-2xl p-10 text-center text-blue-700">
          <div className="text-4xl mb-3">📋</div>
          {groups.length === 0 ? 'Create groups first (Step ②), then generate the schedule.' : 'Click Generate Schedule to build the match order.'}
        </div>
      ) : (
        rounds.map(round => (
          <div key={round} className="mb-7">
            <div className="flex items-center gap-3 mb-3">
              <h2 className="font-bold text-lg text-white bg-blue-900 px-4 py-1.5 rounded-full">Round {round}</h2>
              <span className="text-sm text-gray-400">{matches.filter(m=>m.round===round&&m.winner).length} / {matches.filter(m=>m.round===round).length} done</span>
            </div>
            <div className={`grid gap-4 ${numMats > 1 ? 'md:grid-cols-2' : 'grid-cols-1'}`}>
              {mats.map(mat => {
                const mm = matches.filter(m => m.round === round && m.mat === mat);
                if (!mm.length) return null;
                return (
                  <div key={mat} className="bg-white rounded-2xl shadow p-4">
                    <div className="flex items-center gap-2 mb-3">
                      <span className="bg-gray-800 text-white font-bold px-3 py-1 rounded-lg text-sm">Mat {mat}</span>
                    </div>
                    <div className="space-y-2">
                      {mm.map(m => (
                        <div key={m.id} className={`flex items-center gap-2 px-3 py-2.5 rounded-xl text-sm ${m.winner ? 'bg-green-50' : 'bg-gray-50'}`}>
                          <span className="bg-blue-100 text-blue-800 text-xs font-bold px-2 py-0.5 rounded-full shrink-0">{m.groupLabel}</span>
                          <span className={`font-medium flex-1 ${m.winner === m.w1.id ? 'text-green-700' : ''}`}>{m.w1.name}</span>
                          <span className="text-gray-300 font-bold text-xs">VS</span>
                          <span className={`font-medium flex-1 text-right ${m.winner === m.w2.id ? 'text-green-700' : ''}`}>{m.w2.name}</span>
                          {m.winner ? <span className="text-green-500 text-xs shrink-0">✓</span> : <span className="text-gray-300 text-xs shrink-0">—</span>}
                        </div>
                      ))}
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        ))
      )}
    </div>
  );
}

function ResultsPage({ matches, setMatches }) {
  const [filter, setFilter] = useState('all');
  const pick = (matchId, winnerId) => setMatches(matches.map(m => m.id === matchId ? { ...m, winner: winnerId } : m));
  const rounds = [...new Set(matches.map(m => m.round))].sort((a,b)=>a-b);
  const done = matches.filter(m => m.winner).length;
  const pct  = matches.length ? Math.round(done / matches.length * 100) : 0;
  const filtered = (round) => matches.filter(m => {
    if (m.round !== round) return false;
    if (filter === 'pending')   return !m.winner;
    if (filter === 'completed') return !!m.winner;
    return true;
  });

  return (
    <div className="p-6 max-w-3xl mx-auto">
      <h1 className="text-2xl font-bold text-blue-950 mb-6">④ Live Results Entry</h1>
      {matches.length === 0 ? (
        <div className="bg-blue-50 border border-blue-200 rounded-2xl p-10 text-center text-blue-700">
          <div className="text-4xl mb-3">🎯</div>Generate a schedule first (Step ③).
        </div>
      ) : (
        <>
          <div className="bg-white rounded-2xl shadow p-4 mb-6">
            <div className="flex items-center justify-between mb-2 text-sm">
              <span className="font-semibold text-gray-700">Tournament Progress</span>
              <span className="font-bold text-blue-800">{done} / {matches.length} · {pct}%</span>
            </div>
            <div className="h-3 bg-gray-100 rounded-full overflow-hidden">
              <div className="h-3 bg-gradient-to-r from-blue-500 to-green-500 rounded-full transition-all" style={{ width: pct + '%' }} />
            </div>
            <div className="flex gap-2 mt-3">
              {['all','pending','completed'].map(f => (
                <button key={f} onClick={() => setFilter(f)}
                  className={`px-3 py-1 rounded-lg text-xs font-medium capitalize ${filter === f ? 'bg-blue-700 text-white' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`}
                >{f}</button>
              ))}
            </div>
          </div>
          {rounds.map(round => {
            const rm = filtered(round);
            if (!rm.length) return null;
            return (
              <div key={round} className="mb-6">
                <h2 className="font-bold text-blue-900 mb-3 bg-blue-100 px-4 py-2 rounded-xl">
                  Round {round} <span className="ml-2 text-blue-500 font-normal text-sm">({matches.filter(m=>m.round===round&&m.winner).length}/{matches.filter(m=>m.round===round).length})</span>
                </h2>
                <div className="space-y-3">
                  {rm.map(m => (
                    <div key={m.id} className={`bg-white rounded-2xl shadow border-2 p-4 transition-all ${m.winner ? 'border-green-300' : 'border-transparent'}`}>
                      <div className="flex items-center justify-between mb-3">
                        <div className="flex items-center gap-2">
                          <span className="text-xs bg-blue-100 text-blue-800 font-bold px-2 py-0.5 rounded-full">Group {m.groupLabel}</span>
                          <span className="text-xs text-gray-400">Mat {m.mat}</span>
                        </div>
                        {m.winner && <button onClick={() => pick(m.id, null)} className="text-xs text-gray-400 hover:text-red-500 underline">Undo</button>}
                      </div>
                      <div className="flex items-center gap-3">
                        {[m.w1, m.w2].map((wrestler, idx) => (
                          <React.Fragment key={wrestler.id}>
                            <button onClick={() => pick(m.id, wrestler.id)}
                              className={`flex-1 py-4 rounded-xl font-semibold text-sm border-2 transition-all shadow-sm ${
                                m.winner === wrestler.id ? 'bg-green-500 text-white border-green-500' :
                                m.winner ? 'bg-gray-50 text-gray-300 border-gray-100' :
                                'border-blue-200 hover:border-blue-500 hover:bg-blue-50 text-blue-900'
                              }`}>
                              <div>{wrestler.name}</div>
                              <div className="text-xs mt-1 opacity-70 font-normal">{wrestler.weight}lbs · {wrestler.experience} · Age {wrestler.age}</div>
                              {m.winner === wrestler.id && <div className="text-lg mt-1">🏆</div>}
                            </button>
                            {idx === 0 && <span className="text-gray-300 font-black text-sm shrink-0">VS</span>}
                          </React.Fragment>
                        ))}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            );
          })}
        </>
      )}
    </div>
  );
}

function StandingsPage({ groups, matches }) {
  const PLACE_ICONS = ['🥇','🥈','🥉','4th'];
  return (
    <div className="p-6 max-w-4xl mx-auto">
      <h1 className="text-2xl font-bold text-blue-950 mb-6">⑤ Standings &amp; Placements</h1>
      {groups.length === 0 ? (
        <div className="bg-blue-50 border border-blue-200 rounded-2xl p-10 text-center text-blue-700">
          <div className="text-4xl mb-3">🏆</div>No groups yet. Complete steps ①–③ first.
        </div>
      ) : (
        <div className="space-y-6">
          {groups.map(group => {
            const standings = computeStandings(group, matches);
            const groupMatches = matches.filter(m => m.groupId === group.id);
            const total = groupMatches.length;
            const completed = groupMatches.filter(m => m.winner).length;
            const finished = total > 0 && completed === total;
            return (
              <div key={group.id} className="bg-white rounded-2xl shadow overflow-hidden">
                <div className="bg-blue-950 text-white px-5 py-3 flex items-center justify-between">
                  <h2 className="font-bold text-lg">Group {group.label}</h2>
                  <div className="flex items-center gap-3 text-sm">
                    <span className="text-blue-300">{completed}/{total} matches</span>
                    {finished && <span className="bg-green-500 text-white text-xs px-2 py-0.5 rounded-full font-semibold">FINAL</span>}
                  </div>
                </div>
                {total > 0 && (
                  <div className="h-1 bg-gray-100">
                    <div className="h-1 bg-green-500 transition-all" style={{ width: (completed/total*100)+'%' }} />
                  </div>
                )}
                <table className="w-full text-sm">
                  <thead>
                    <tr className="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
                      <th className="text-left px-4 py-2">Place</th>
                      <th className="text-left px-4 py-2">Wrestler</th>
                      <th className="text-left px-4 py-2 hidden sm:table-cell">Details</th>
                      <th className="text-center px-4 py-2 text-green-700">W</th>
                      <th className="text-center px-4 py-2 text-red-500">L</th>
                      <th className="text-center px-4 py-2 text-blue-800">Pts</th>
                    </tr>
                  </thead>
                  <tbody>
                    {standings.map((s, i) => (
                      <tr key={s.wrestler.id} className={`border-t transition-colors ${i === 0 && finished ? 'bg-yellow-50' : ''}`}>
                        <td className="px-4 py-3 text-lg w-14 text-center">{PLACE_ICONS[i] || `${i+1}.`}</td>
                        <td className="px-4 py-3 font-semibold">{s.wrestler.name}</td>
                        <td className="px-4 py-3 hidden sm:table-cell">
                          <div className="flex items-center gap-2">
                            <Badge text={s.wrestler.experience} />
                            <span className="text-gray-400 text-xs">{s.wrestler.weight}lbs · Age {s.wrestler.age} · {s.wrestler.grade}</span>
                          </div>
                        </td>
                        <td className="px-4 py-3 text-center font-bold text-green-700 text-base">{s.wins}</td>
                        <td className="px-4 py-3 text-center text-red-400">{s.losses}</td>
                        <td className="px-4 py-3 text-center font-bold text-blue-800 text-base">{s.points}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

function App() {
  const [page,       setPage]       = useState('upload');
  const [wrestlers,  setWrestlers]  = useState(() => load('wrestlers', []));
  const [groups,     setGroups]     = useState(() => load('groups', []));
  const [unassigned, setUnassigned] = useState(() => load('unassigned', []));
  const [matches,    setMatches]    = useState(() => load('matches', []));
  const [numMats,    setNumMats]    = useState(() => load('numMats', 2));

  useEffect(() => { save('wrestlers',  wrestlers);  }, [wrestlers]);
  useEffect(() => { save('groups',     groups);     }, [groups]);
  useEffect(() => { save('unassigned', unassigned); }, [unassigned]);
  useEffect(() => { save('matches',    matches);    }, [matches]);
  useEffect(() => { save('numMats',    numMats);    }, [numMats]);

  return (
    <div className="min-h-screen bg-gray-100">
      <Nav page={page} setPage={setPage} wrestlers={wrestlers} groups={groups} />
      <div className="pb-12">
        {page === 'upload'    && <UploadPage    wrestlers={wrestlers}  setWrestlers={setWrestlers} />}
        {page === 'groups'    && <GroupsPage    wrestlers={wrestlers}  groups={groups}     setGroups={setGroups}
                                               unassigned={unassigned} setUnassigned={setUnassigned} setMatches={setMatches} />}
        {page === 'schedule'  && <SchedulePage  groups={groups}        numMats={numMats}   setNumMats={setNumMats}
                                               matches={matches}       setMatches={setMatches} />}
        {page === 'results'   && <ResultsPage   matches={matches}      setMatches={setMatches} />}
        {page === 'standings' && <StandingsPage groups={groups}        matches={matches} />}
      </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App />);
</script>
</body>
</html>
